{
  "name": "@goodit/evals",
  "version": "0.7.0",
  "description": "Pragmatic eval framework for LLM features. Runs eval files as Bun tests with scorers, baselines, and reporting.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neoromantic/evals.git"
  },
  "keywords": [
    "evals",
    "llm",
    "ai",
    "testing",
    "bun",
    "scorers",
    "baseline"
  ],
  "scripts": {
    "build": "bun run clean && tsc -p tsconfig.json && bun scripts/fix-dist-imports.ts",
    "eval": "bun src/run.ts",
    "eval:select": "bun src/run.ts select",
    "eval:update": "UPDATE_BASELINE=1 bun src/run.ts",
    "test": "bun test src/*.test.ts scripts/*.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "prepack": "bun run build",
    "release": "bun scripts/release.ts",
    "release:dry-run": "bun scripts/release.ts --dry-run"
  },
  "bin": {
    "goodit-evals": "bin/goodit-evals"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./preload": {
      "types": "./dist/src/preload.d.ts",
      "bun": "./src/preload.ts",
      "import": "./dist/src/preload.js",
      "default": "./dist/src/preload.js"
    }
  },
  "files": [
    "bin",
    "src/*.ts",
    "!src/*.test.ts",
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "ai": ">=6",
    "zod": ">=3"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@types/bun": "^1.3.10",
    "@types/react": "^19.2.14",
    "ai": "^6.0.116",
    "autoevals": "^0.0.132",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "react": "^19.2.4"
  }
}
